# =============================================
# CONFIGURACIÓN DE EJEMPLO - NO USAR EN PRODUCCIÓN
# =============================================
# Copia este archivo como .env y configura tus valores reales

# =============================================
# ENTORNO
# =============================================
ENVIRONMENT=development

# =============================================
# SEGURIDAD - CONTROL DE EJECUCIÓN
# =============================================
# Importante: Estas variables controlan la seguridad del sistema
# NO modificar en entornos de producción sin aprobación

# Bloquea cualquier ejecución real de operaciones de trading
# Valores posibles: True (permite ejecución) / False (bloquea)
ALLOW_REAL_EXECUTION=False

# Requiere aprobación manual antes de ejecutar operaciones
# Valores posibles: True (requiere aprobación) / False (automático)
REQUIRE_APPROVAL=True

# =============================================
# BASE DE DATOS (desarrollo local)
# =============================================
DATABASE_URL=sqlite:///antigravity_core.db

# =============================================
# API KEYS (opcionales para desarrollo)
# =============================================
# Añade tus API keys aquí si las necesitas para testing
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant...

# =============================================
# CONFIGURACIÓN DE TRADING (solo para paper trading)
# =============================================
# MT5_CONFIG={"account": "...", "password": "...", "server": "..."}
